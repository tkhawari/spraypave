---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact — Request a free quote"
  description="Request a free on-site quote for spray paving across the Illawarra, Shoalhaven and Southern Highlands. We'll inspect your concrete and give you an honest fixed price."
>
  <!-- Page header -->
  <section class="py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <p class="text-sm font-inter font-medium uppercase tracking-widest text-mute mb-4">
        Get in touch
      </p>
      <h1
        class="font-fraunces font-medium text-4xl md:text-5xl text-ink tracking-tight mb-6"
      >
        Request a free quote
      </h1>
      <p class="font-inter text-base md:text-lg text-char leading-relaxed max-w-2xl">
        Tell us about your project and we'll arrange a free on-site consultation. We'll inspect
        your concrete, talk through finish and colour options, and give you an honest fixed price
        — no obligation.
      </p>
    </div>
  </section>

  <!-- Form + contact details -->
  <section class="pb-24 md:pb-32">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-12 lg:gap-16 items-start">

        <!-- Left: Quote form -->
        <div>
          <form method="post" action="https://formspree.io/f/a64abbbc-b7ec-49ed-b189-20e474817b69" novalidate class="space-y-6">

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <!-- Name -->
              <div>
                <label for="name" class="block text-sm font-inter font-medium text-ink mb-1.5">
                  Full name <span class="text-clay" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  autocomplete="name"
                  placeholder="Jane Smith"
                  class="w-full border border-line rounded-sm px-4 py-3 font-inter text-base text-ink bg-bone placeholder:text-mute focus:outline-none focus:border-clay transition-colors"
                />
              </div>

              <!-- Phone -->
              <div>
                <label for="phone" class="block text-sm font-inter font-medium text-ink mb-1.5">
                  Phone <span class="text-clay" aria-hidden="true">*</span>
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  autocomplete="tel"
                  placeholder="0400 000 000"
                  class="w-full border border-line rounded-sm px-4 py-3 font-inter text-base text-ink bg-bone placeholder:text-mute focus:outline-none focus:border-clay transition-colors"
                />
              </div>
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-inter font-medium text-ink mb-1.5">
                Email <span class="text-clay" aria-hidden="true">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                placeholder="jane@example.com"
                class="w-full border border-line rounded-sm px-4 py-3 font-inter text-base text-ink bg-bone placeholder:text-mute focus:outline-none focus:border-clay transition-colors"
              />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <!-- Suburb -->
              <div>
                <label for="suburb" class="block text-sm font-inter font-medium text-ink mb-1.5">
                  Suburb <span class="text-clay" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="suburb"
                  name="suburb"
                  required
                  autocomplete="address-level2"
                  placeholder="Wollongong"
                  class="w-full border border-line rounded-sm px-4 py-3 font-inter text-base text-ink bg-bone placeholder:text-mute focus:outline-none focus:border-clay transition-colors"
                />
              </div>

              <!-- Surface type -->
              <div>
                <label for="surface" class="block text-sm font-inter font-medium text-ink mb-1.5">
                  Surface type <span class="text-clay" aria-hidden="true">*</span>
                </label>
                <div class="relative">
                  <select
                    id="surface"
                    name="surface"
                    required
                    class="w-full border border-line rounded-sm px-4 py-3 font-inter text-base text-ink bg-bone appearance-none focus:outline-none focus:border-clay transition-colors cursor-pointer"
                  >
                    <option value="" disabled selected>Select a surface…</option>
                    <option value="driveway">Driveway</option>
                    <option value="patio">Patio</option>
                    <option value="pool-surround">Pool surround</option>
                    <option value="courtyard">Courtyard</option>
                    <option value="garage-floor">Garage floor</option>
                    <option value="pathway">Pathway</option>
                    <option value="commercial-carpark">Commercial carpark</option>
                    <option value="factory-floor">Factory floor</option>
                    <option value="epoxy">Epoxy flooring</option>
                    <option value="other">Other / not sure</option>
                  </select>
                  <div
                    class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-mute"
                    aria-hidden="true"
                  >
                    <svg
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                  </div>
                </div>
              </div>
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-inter font-medium text-ink mb-1.5">
                Project details
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                placeholder="Tell us about your project — approximate size, condition of the existing surface, any finish or colour preferences."
                class="w-full border border-line rounded-sm px-4 py-3 font-inter text-base text-ink bg-bone placeholder:text-mute focus:outline-none focus:border-clay transition-colors resize-none"
              ></textarea>
              <p class="mt-1.5 text-xs font-inter text-mute">
                Optional — the more detail you share, the more useful our first visit will be.
              </p>
            </div>

            <button
              type="submit"
              class="inline-block px-8 py-3.5 bg-clay text-white font-inter font-medium text-base rounded-sm hover:bg-clay-dark transition-colors focus-visible:outline-2 focus-visible:outline-clay focus-visible:outline-offset-2"
            >
              Request free quote
            </button>
          </form>
        </div>

        <!-- Right: Contact details -->
        <div class="space-y-4">

          <!-- Phone + email -->
          <div class="bg-paper border border-line rounded-sm p-6 space-y-5">
            <!-- Phone -->
            <div>
              <p class="text-xs font-inter font-medium uppercase tracking-widest text-mute mb-2">
                Call us
              </p>
              <a
                href="tel:[PHONE_NUMBER]"
                class="flex items-center gap-3 text-ink hover:text-clay transition-colors no-underline"
              >
                <span class="flex-shrink-0 text-clay" aria-hidden="true">
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path
                      d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.55 3.4 2 2 0 0 1 3.54 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.72a16 16 0 0 0 6 6l.9-.9a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                    ></path>
                  </svg>
                </span>
                <span class="font-inter font-medium text-base">[PHONE_NUMBER]</span>
              </a>
            </div>

            <div class="border-t border-line"></div>

            <!-- Email -->
            <div>
              <p class="text-xs font-inter font-medium uppercase tracking-widest text-mute mb-2">
                Email us
              </p>
              <a
                href="mailto:[EMAIL_ADDRESS]"
                class="flex items-center gap-3 text-ink hover:text-clay transition-colors no-underline"
              >
                <span class="flex-shrink-0 text-clay" aria-hidden="true">
                  <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect x="2" y="4" width="20" height="16" rx="2"></rect>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                  </svg>
                </span>
                <span class="font-inter font-medium text-base">[EMAIL_ADDRESS]</span>
              </a>
            </div>
          </div>

          <!-- Business hours -->
          <div class="bg-paper border border-line rounded-sm p-6">
            <div class="flex items-center gap-2.5 mb-4">
              <span class="text-clay" aria-hidden="true">
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="12" cy="12" r="10"></circle>
                  <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
              </span>
              <p class="text-xs font-inter font-medium uppercase tracking-widest text-mute">
                Business hours
              </p>
            </div>
            <dl class="space-y-2.5">
              <div class="flex justify-between gap-4 text-sm font-inter">
                <dt class="text-char">Monday – Friday</dt>
                <dd class="text-ink font-medium shrink-0">7:00 am – 5:00 pm</dd>
              </div>
              <div class="flex justify-between gap-4 text-sm font-inter">
                <dt class="text-char">Saturday</dt>
                <dd class="text-ink font-medium shrink-0">8:00 am – 12:00 pm</dd>
              </div>
              <div class="flex justify-between gap-4 text-sm font-inter">
                <dt class="text-char">Sunday</dt>
                <dd class="text-mute shrink-0">Closed</dd>
              </div>
            </dl>
          </div>

          <!-- Service area -->
          <div class="bg-paper border border-line rounded-sm p-6">
            <div class="flex items-center gap-2.5 mb-4">
              <span class="text-clay" aria-hidden="true">
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
              </span>
              <p class="text-xs font-inter font-medium uppercase tracking-widest text-mute">
                Service area
              </p>
            </div>
            <ul class="space-y-2 text-sm font-inter text-char">
              <li>Illawarra (Thirroul to Shellharbour)</li>
              <li>Kiama</li>
              <li>Shoalhaven (to Nowra)</li>
              <li>Southern Highlands — Bowral, Mittagong, Moss Vale</li>
            </ul>
          </div>

          <!-- ABN -->
          <p class="text-xs font-inter text-mute px-1">ABN: [ABN]</p>

        </div>
      </div>
    </div>
  </section>
</Layout>
