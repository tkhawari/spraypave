---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Services">
  <main class="max-w-6xl mx-auto px-6 md:px-8 py-24">
    <h1 class="font-fraunces font-medium text-4xl md:text-5xl text-ink tracking-tight mb-6">
      Services
    </h1>
    <p class="font-inter text-base md:text-lg text-char leading-relaxed">
      Coming soon — we're working on this. In the meantime, <a
        href="tel:[PHONE_NUMBER]"
        class="text-clay hover:text-clay-dark transition-colors focus-visible:outline-2 focus-visible:outline-clay focus-visible:outline-offset-2 rounded-sm"
        >give us a call</a
      > or <a
        href="/contact"
        class="text-clay hover:text-clay-dark transition-colors focus-visible:outline-2 focus-visible:outline-clay focus-visible:outline-offset-2 rounded-sm"
        >send a message</a
      >.
    </p>
  </main>
</Layout>
