---
const services = [
  'Driveways',
  'Patios',
  'Pool surrounds',
  'Courtyards',
  'Garage floors',
  'Pathways',
  'Commercial carparks',
  'Factory floors',
  'Epoxy flooring',
];

const areas = [
  'Wollongong',
  'Shellharbour',
  'Kiama',
  'Nowra',
  'Bowral',
  'Mittagong',
  'Moss Vale',
  'Gerringong',
];
---

<footer class="bg-ink text-bone">
  <div
    class="max-w-6xl mx-auto px-6 md:px-8 py-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12"
  >
    <!-- Brand block -->
    <div>
      <p class="font-fraunces font-medium text-lg mb-3">Illawarra Spray Pave</p>
      <p class="text-sm text-neutral-400 leading-relaxed">
        Premium spray paving across the Illawarra, Shoalhaven and Southern Highlands.
      </p>
    </div>

    <!-- Services -->
    <div>
      <p class="text-xs font-medium uppercase tracking-widest mb-4">Services</p>
      <ul class="space-y-2">
        {
          services.map((service) => (
            <li>
              <a
                href="/services"
                class="text-sm text-neutral-400 hover:text-white transition-colors no-underline focus-visible:outline-2 focus-visible:outline-clay focus-visible:outline-offset-2 rounded-sm"
              >
                {service}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Areas -->
    <div>
      <p class="text-xs font-medium uppercase tracking-widest mb-4">We serve</p>
      <ul class="space-y-2">
        {areas.map((area) => <li class="text-sm text-neutral-400">{area}</li>)}
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <p class="text-xs font-medium uppercase tracking-widest mb-4">Contact</p>
      <div class="space-y-2">
        <p>
          <a
            href="tel:[PHONE_NUMBER]"
            class="text-sm text-neutral-400 hover:text-white transition-colors no-underline focus-visible:outline-2 focus-visible:outline-clay focus-visible:outline-offset-2 rounded-sm"
          >
            [PHONE_NUMBER]
          </a>
        </p>
        <p>
          <a
            href="mailto:[EMAIL_ADDRESS]"
            class="text-sm text-neutral-400 hover:text-white transition-colors no-underline focus-visible:outline-2 focus-visible:outline-clay focus-visible:outline-offset-2 rounded-sm"
          >
            [EMAIL_ADDRESS]
          </a>
        </p>
        <p class="text-sm text-neutral-400">ABN [ABN] — fully insured</p>
      </div>
    </div>
  </div>

  <!-- Bottom strip -->
  <div class="border-t border-neutral-800">
    <div class="max-w-6xl mx-auto px-6 md:px-8 py-4">
      <p class="text-sm text-mute">© 2026 Illawarra Spray Pave</p>
    </div>
  </div>
</footer>
